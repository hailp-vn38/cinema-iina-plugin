{
  "name": "cinema-iina-plugin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "build:ui": "node scripts/build-ui-inline.mjs",
    "build:runtime": "node scripts/build-runtime.mjs",
    "build:global": "node scripts/build-global.mjs",
    "package": "npm run build:ui && npm run build:runtime && npm run build:global && node scripts/package-plugin.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "esbuild": "0.25.5",
    "typescript": "^6.0.3",
    "vite": "5.4.10"
  }
}
